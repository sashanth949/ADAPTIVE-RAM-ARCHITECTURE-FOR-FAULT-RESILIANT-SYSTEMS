module c_ram (
    input clk,            // Clock signal
    input CS,             // Chip Select (Active High)
    input RW,             // Read/Write Enable (1 = Write, 0 = Read)
    input [5:0] addr,     // 6-bit Address bus (2^6 = 64 locations)
    input [7:0] in,       // 8-bit Data Input
    output reg [7:0] out  // 8-bit Data Output
);

    // Memory array: 64 words, each 8 bits wide
    reg [7:0] data [63:0];

    always @(posedge clk) begin
        if (CS) begin
            if (RW) begin
                // Write Operation
                data[addr] <= in;
            end else begin
                // Read Operation
                out <= data[addr];
            end
        end
    end

endmodule
